@model Case_AeC.Models.Usuario
@{
    ViewData["Title"] = "Cadastrar Usuário";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="mb-4 text-center">
            <h4 class="mb-0 text-primary fw-bold"> Criar Nova Conta</h4>
        </div>      
        <div class="card-body">
            <form asp-action="Criar">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Nome" class="control-label"> Nome Completo</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Login" class="control-label"> Usuário (Login)</label>
                    <input asp-for="Login" class="form-control" />
                    <span asp-validation-for="Login" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Senha" class="control-label"> Senha</label>
                    <input asp-for="Senha" type="password" class="form-control" />
                    <span asp-validation-for="Senha" class="text-danger"></span>
                </div>

                <div class="form-group d-grid gap-2">
                    <button type="submit" class="btn btn-success">Criar Conta</button>
                    <a asp-action="Login" class="btn btn-link">Já tenho uma conta</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}