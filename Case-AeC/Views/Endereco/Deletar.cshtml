@model Case_AeC.Models.Endereco
@{
    ViewData["Title"] = "Excluir Endereço";
}

<h3>Tem certeza que deseja Excluir este endereço?</h3>
<div>
    <p><strong>Logradouro:</strong> @Model.Logradouro, @Model.Numero</p>
    <p><strong>Cidade:</strong> @Model.Cidade - @Model.UF</p>
</div>

<form asp-action="Deletar">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>