@model IEnumerable<Case_AeC.Models.Endereco>
@{
    ViewData["Title"] = "Endereços";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Endereços Cadastrados</h2>
        <div>
            <a asp-action="ExportarCSV" class="btn btn-success">
                <i class="bi bi-file-earmark-arrow-down"></i> Exportar CSV
            </a>
            
            <a asp-action="Criar" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Novo Endereço
            </a>
        </div>
    </div>


    <table class="table table-hover table-striped border">
        <thead class="table-dark">
            <tr>
                <th>CEP</th>
                <th>Logradouro</th>
                <th>Bairro</th>
                <th>Cidade</th>
                <th>UF</th>
                <th class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Cep</td>
                        <td>@item.Logradouro</td>
                        <td>@item.Bairro</td>
                        <td>@item.Cidade</td>
                        <td>@item.UF</td>
                        <td class="text-center">
                            <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Deletar"asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">Nenhum endereço cadastrado.</td>
                </tr>
            }
        </tbody>
    </table>
</div>